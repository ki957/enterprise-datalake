{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI Server (ai-agent)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["services.ai-agent.server:app", "--reload", "--port", "8502"],
      "jinja": true
    },
    {
      "name": "Debug Airflow DAG",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/orchestration/airflow/dags/saas_pipeline.py",
      "console": "integratedTerminal"
    },
    {
      "name": "React Frontend (Vite)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/services/ai-agent-v2/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "pytest Current File",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal"
    }
  ]
}
