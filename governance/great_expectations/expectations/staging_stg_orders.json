{
  "data_asset_type": null,
  "expectation_suite_name": "staging_stg_orders",
  "expectations": [

    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {"min_value": 100, "max_value": 10000000},
      "meta": {"notes": "Staging orders must have at least 100 rows after MySQL CDC sync"}
    },

    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "customer_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "product_id"},
      "meta": {}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "amount"},
      "meta": {}
    },

    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "status",
        "value_set": ["pending", "completed", "cancelled"]
      },
      "meta": {}
    },

    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "amount", "min_value": 0.01},
      "meta": {"notes": "All staging order amounts must be positive"}
    },

    {
      "expectation_type": "expect_column_proportion_of_unique_values_to_be_between",
      "kwargs": {"column": "order_id", "min_value": 0.99},
      "meta": {}
    }
  ],
  "meta": {
    "great_expectations_version": "0.18.0"
  }
}
