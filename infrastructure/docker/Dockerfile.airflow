FROM apache/airflow:2.8.0-python3.11
USER airflow
# Pin dbt-core to prevent pip resolver backtracking (dbt-clickhouse allows >=1.7,<2)
RUN pip install --no-cache-dir --user \
    "dbt-core==1.8.9" \
    "dbt-clickhouse==1.8.7" \
    "typing_extensions>=4.10" \
    minio \
    pyarrow \
    requests \
    psycopg2-binary \
    apache-airflow-providers-hashicorp==3.6.0 \
    ruamel.yaml \
    mysql-connector-python \
    kafka-python \
    groq \
    clickhouse-driver
