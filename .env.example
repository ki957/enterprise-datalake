# ============================================================
# Enterprise Data Lake — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values before running.
# NEVER commit .env — it is git-ignored.
#
# All services read credentials from this file at startup.
# After changing values, restart the affected containers:
#   docker compose --env-file .env -f infrastructure/docker/docker-compose.<layer>.yml up -d
# ============================================================

# ── MINIO ─────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme_minio

# ── CLICKHOUSE ────────────────────────────────────────────────
CLICKHOUSE_DEFAULT_USER=default
CLICKHOUSE_DEFAULT_PASSWORD=changeme_clickhouse
# URL used by Airflow DAG to run ad-hoc SQL checks
CLICKHOUSE_URL=http://clickhouse:8123/
# Credentials used by dbt inside Airflow (may differ from default)
DBT_CLICKHOUSE_USER=default
DBT_CLICKHOUSE_PASSWORD=changeme_clickhouse

# ── POSTGRES (Airflow + Superset metadata backend) ────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=airflow

# ── AIRFLOW ───────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_airflow
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=changeme_generate_with_python
AIRFLOW_WEBSERVER_SECRET_KEY=changeme_airflow_webserver_secret

# ── KEYCLOAK ──────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak
KEYCLOAK_DB_PASSWORD=changeme_keycloak_db

# ── VAULT ─────────────────────────────────────────────────────
# Dev-mode root token — used only during `make setup-vault` bootstrap.
# Airflow authenticates via AppRole, NOT the root token.
VAULT_DEV_ROOT_TOKEN_ID=root
# Generated by `make setup-vault` — copy values from the script output.
VAULT_APPROLE_ROLE_ID=<generated-by-make-setup-vault>
VAULT_APPROLE_SECRET_ID=<generated-by-make-setup-vault>

# ── SUPERSET ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=changeme_superset_key
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=changeme_superset
SUPERSET_URL=http://superset:8088
SUPERSET_USER=admin
SUPERSET_PASSWORD=changeme_superset

# ── GRAFANA ───────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana
# ── REDIS ─────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── MYSQL (ShopFlow CDC source) ───────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_mysql
MYSQL_DATABASE=shopflow

# ── AIRBYTE ───────────────────────────────────────────────────
AIRBYTE_URL=http://airbyte-abctl-control-plane:80
# Find these in the Airbyte UI → Settings → Applications
AIRBYTE_CLIENT_ID=<your-airbyte-client-id>
AIRBYTE_CLIENT_SECRET=<your-airbyte-client-secret>
AIRBYTE_MYSQL_CONN_ID=<your-mysql-connection-id>

# ── NOTIFICATIONS ─────────────────────────────────────────────
# Create an Incoming Webhook in Slack: https://api.slack.com/messaging/webhooks
# Leave empty to disable (alerts will only appear in Airflow logs).
SLACK_WEBHOOK_URL=

# ── AI AGENT ──────────────────────────────────────────────────
# Get your API key at: https://console.groq.com
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── SAP / REST API SOURCES ────────────────────────────────────
SAP_BASE_URL=http://sap-api:5001
JSON_BASE_URL=https://jsonplaceholder.typicode.com

# ── DATALAKE RUNTIME ──────────────────────────────────────────
# Mount point inside Airflow container (set via volume in governance compose)
DATALAKE_HOME=/opt/datalake
# Postgres host/port for DAGs running on host (change when running outside Docker)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# MinIO endpoint for DAGs / Spark jobs
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=changeme_minio
